# =============================================================================
# Leihs Docker Compose - Environment Configuration
# =============================================================================
# Copy this file to .env and adjust values for your deployment.

# -- Leihs Version -----------------------------------------------------------
# Git tag/branch to build from (check https://github.com/leihs/leihs/releases)
LEIHS_VERSION=7.13.3

# -- External Access ----------------------------------------------------------
# The public hostname where leihs will be accessible
LEIHS_EXTERNAL_HOSTNAME=leihs.example.com
LEIHS_EXTERNAL_BASE_URL=https://leihs.example.com

# Port exposed on the Docker host
LEIHS_HTTP_PORT=3100

# -- Database -----------------------------------------------------------------
POSTGRES_DB=leihs
POSTGRES_USER=leihs
POSTGRES_PASSWORD=CHANGE_ME_GENERATE_WITH_SCRIPT
POSTGRES_PORT=5415

# -- Leihs Master Secret -----------------------------------------------------
# Shared secret between all leihs services (generate with ./scripts/generate-secrets.sh)
LEIHS_MASTER_SECRET=CHANGE_ME_GENERATE_WITH_SCRIPT

# -- Authentik OIDC Configuration (optional) ----------------------------------
# Leave empty to use password-only authentication
AUTHENTIK_ISSUER_URL=https://auth.example.com/application/o/leihs/
AUTHENTIK_CLIENT_ID=
AUTHENTIK_CLIENT_SECRET=
# Where Authentik redirects after login (must match Authentik redirect URI config)
OIDC_REDIRECT_URI=https://leihs.example.com/authenticators/oidc/callback

# -- OIDC Bridge Keys --------------------------------------------------------
# ES256 key paths (generated by ./scripts/generate-secrets.sh)
# These are mounted into containers - do not change paths
OIDC_BRIDGE_PRIVATE_KEY_PATH=/keys/oidc-bridge-private.pem
OIDC_BRIDGE_PUBLIC_KEY_PATH=/keys/oidc-bridge-public.pem
LEIHS_PUBLIC_KEY_PATH=/keys/leihs-public.pem
LEIHS_PRIVATE_KEY_PATH=/keys/leihs-private.pem

# -- SMTP (optional, for email notifications) ---------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=leihs@example.com
SMTP_DOMAIN=example.com

# -- Java / JVM Settings -----------------------------------------------------
# Default heap size for Clojure services (admin, borrow, my, procure)
JAVA_OPTS=-Xmx1G
